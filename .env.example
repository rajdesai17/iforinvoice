DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="replace-with-strong-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Development fallback user when no active session exists.
# Remove in production to enforce authenticated sessions only.
DEMO_USER_ID="00000000-0000-0000-0000-000000000001"

# Optional: set true only for scripts/tests that do not require full env.
SKIP_ENV_VALIDATION="false"
